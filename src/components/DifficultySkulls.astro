---
interface Props {
  level: number;
}
const { level } = Astro.props;
const skulls = [1, 2, 3, 4, 5];
---
<div class="difficulty">
  <span class="lbl">Erfiðleiki</span>
  <span class="skulls">
    {skulls.map(i => (
      <span class={`skull${i <= level ? ' on' : ''}`}></span>
    ))}
  </span>
</div>
