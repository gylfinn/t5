---
interface Props {
  level: number;
  compact?: boolean;
}
const { level, compact = false } = Astro.props;
const skulls = [1, 2, 3, 4, 5];
---
<div class:list={['difficulty', compact && 'difficulty-compact']}>
  {!compact && <span class="lbl">Erfiðleiki</span>}
  <span class="skulls">
    {skulls.map(i => (
      <span class={`skull${i <= level ? ' on' : ''}`}></span>
    ))}
  </span>
</div>
