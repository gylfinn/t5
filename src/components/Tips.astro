---
interface Card {
  title: string;
  items: string[];
}

const cards: Card[] = [
  {
    title: 'Fyrir Raid Leiðtoga',
    items: [
      '<strong>Byrjaðu á Void Reaver</strong> til að venjast The Eye trash',
      '<strong>SSC kill order:</strong> Hydross → Lurker → Tidewalker → Karathress → Leotheras → Vashj',
      '<strong>The Eye kill order:</strong> Void Reaver → Solarian → Al\'ar → Kael',
      'Klárið alla 4-5 fyrri bossana á sömu nótt',
      'Vashj og Kael fá sína eigin nótt',
      '<strong>Voice comms</strong> er must fyrir Vashj og Kael',
    ],
  },
  {
    title: 'Resistance Krafa',
    items: [
      '<strong>Hydross:</strong> 365 Frost res + 365 Nature res tankar',
      '<strong>Leotheras:</strong> Engin krafa, en warlock-tank gear',
      '<strong>Vashj:</strong> Engin krafa',
      '<strong>Kael:</strong> Engin krafa, en healers þurfa STA gear',
    ],
  },
  {
    title: 'Consumables',
    items: [
      '<strong>Tankar:</strong> Flask of Fortification, Sharpened Kuna, Major Healing Pots',
      '<strong>Healers:</strong> Flask of Mighty Restoration, Mana pots, Mana Oil',
      '<strong>DPS:</strong> Flask of Relentless Assault / Pure Death',
      '<strong>Allir:</strong> Spicy Crawdad eða Skullfish Soup, Scroll buffs',
    ],
  },
  {
    title: 'Loot Priority Suggestion',
    items: [
      '<strong>T5 helmet</strong> (Solarian/Leotheras) → tankar fyrst',
      '<strong>T5 chest</strong> (Solarian) → tankar',
      '<strong>T5 shoulders</strong> (Void Reaver) → DPS first',
      '<strong>T5 legs</strong> (Kael/Vashj) → caster DPS',
      '<strong>T5 gloves</strong> (Karathress) → melee/healers',
      '<strong>T5 wrists</strong> (Morogrim) → spread evenly',
    ],
  },
  {
    title: 'Lykil Cooldowns',
    items: [
      '<strong>Bloodlust/Heroism:</strong> Save fyrir burn fasa (Solarian P3, Kael P5, Vashj P3, Karathress P4, Morogrim 25%)',
      '<strong>Innervate:</strong> Á healers fyrir Phase 4-5 á Kael',
      '<strong>Mana Tide Totem:</strong> Reglulega fyrir healers',
      '<strong>Soulstone:</strong> Á main healer fyrir wipe protection',
    ],
  },
  {
    title: 'Addons sem mæla með',
    items: [
      '<strong>Deadly Boss Mods (DBM)</strong> — timer fyrir alla mechanics',
      '<strong>Decursive</strong> — quick dispel/cleanse',
      '<strong>Omen</strong> — threat tracking',
      '<strong>Grid eða Healbot</strong> — healer UI',
      '<strong>WeakAuras</strong> — custom alerts (Wrath, MC, Shock Blast)',
    ],
  },
];
---
<section id="tips" class="tips-section">
  <div class="raid-header">
    <div class="label">Hluti III</div>
    <h2>Almennar Ráðleggingar</h2>
    <div class="raid-meta">Consumables, gear og raid leadership</div>
  </div>

  <div class="tips-grid">
    {cards.map(card => (
      <div class="tips-card">
        <h4>{card.title}</h4>
        <ul>
          {card.items.map(item => <li set:html={item} />)}
        </ul>
      </div>
    ))}
  </div>
</section>
