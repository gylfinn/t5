---
interface Card {
  title: string;
  items: string[];
}

const cards: Card[] = [
  {
    title: 'Resistance Krafa',
    items: [
      '<strong>Hydross:</strong> 244-365 Frost res + 244-365 Nature res tankar',
      '<strong>Leotheras:</strong> 244-365 Fire res tank'
    ],
  },
  {
    title: 'Addons sem Hitaveitan mælir með',
    items: [
      '<strong>Threat Meter</strong>',
    ],
  },
];
---
<section id="tips" class="tips-section">
  <div class="raid-header">
    <div class="label">Hluti III</div>
    <h2>Almennar Ráðleggingar</h2>
    <div class="raid-meta">Consumables, gear og raid leadership</div>
  </div>

  <div class="tips-grid">
    {cards.map(card => (
      <div class="tips-card">
        <h4>{card.title}</h4>
        <ul>
          {card.items.map(item => <li set:html={item} />)}
        </ul>
      </div>
    ))}
  </div>
</section>
