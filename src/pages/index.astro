---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import TOC from '../components/TOC.astro';
import Hero from '../components/Hero.astro';
import RaidIntro from '../components/RaidIntro.astro';
import BossCard from '../components/BossCard.astro';
import TrashSection from '../components/TrashSection.astro';
import Tips from '../components/Tips.astro';

const all = (await getCollection('bosses')).sort((a, b) => a.data.order - b.data.order);
const tk = all.filter(b => b.data.raid === 'tk');
const ssc = all.filter(b => b.data.raid === 'ssc');

const trash = await getCollection('trashGroups');
const tkTrash = trash.filter(t => t.data.raid === 'tk');
const sscTrash = trash.filter(t => t.data.raid === 'ssc');

const tkIntro = `The Eye er lúxusvirki <strong>Kael'thas Sunstrider</strong>, svífandi yfir Netherstorm eins og dýrasta Airbnb á öllu Outland. Hitaveitan flýgur upp, drepur þrjá nánustu starfsmenn Sólarprinsins í röð og endar kvöldið með því að taka af honum legendary vopn sem hann eyddi heilli ævi í að safna.`;

const sscIntro = `SSC er neðanjarðar hellir þar sem <strong>Lady Vashj</strong> hefur byggt sér rakt virki djúpt undir Zangarmarsh. Fimm bossar á leiðinni að henni og hver og einn er ný tegund áreitis fyrir Hitaveituna — frá Hydross sem getur ekki gert upp við sig hvort hann sé Frost eða Nature, yfir í Morogrim sem býður allri murloc-fjölskyldunni í kvöldmat á sama tíma.`;
---
<Base title="Raid Leiðbeiningar — Tempest Keep & Serpentshrine Cavern | TBC Anniversary">
  <TOC bosses={all} />
  <Hero />

  <div class="container">
    <section id="tk" class="raid-section">
      <RaidIntro
        label="Raid · Hluti I"
        title="Tempest Keep: The Eye"
        meta="Netherstorm · 4 bossar"
        blurbHtml={tkIntro}
        info={[
          { k: 'Staðsetning', v: 'Netherstorm' },
          { k: 'Bossar', v: '4' }
        ]}
      />
      {tk.map(boss => <BossCard boss={boss} />)}
    </section>

    {tkTrash.length > 0 && <TrashSection raid="tk" groups={tkTrash} />}

    {ssc.length > 0 && (
      <section id="ssc" class="raid-section">
        <RaidIntro
          label="Raid · Hluti II"
          title="Serpentshrine Cavern"
          meta="Coilfang Reservoir, Zangarmarsh · 6 bossar"
          blurbHtml={sscIntro}
          info={[
            { k: 'Staðsetning', v: 'Zangarmarsh' },
            { k: 'Bossar', v: '6' }
          ]}
        />
        {ssc.map(boss => <BossCard boss={boss} />)}
      </section>
    )}

    {sscTrash.length > 0 && <TrashSection raid="ssc" groups={sscTrash} />}

    <Tips />
  </div>

  <footer>
    <div class="closing">"Megi Sólarprinsinn falla og Sjávarnornin sökkva."</div>
    <div>Raid Leiðbeiningar · TBC Anniversary Phase 2 · Overlords of Outland</div>
  </footer>
</Base>
