---
import { ClientRouter } from 'astro:transitions';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Ítarlegur leiðarvísir á íslensku fyrir Tempest Keep og Serpentshrine Cavern í TBC Anniversary Phase 2. Tíu bossar með mechanics, phases og strategy.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const bgImageUrl = `${base}/images/hitaveitan_bg.svg`;
const ogImageUrl = Astro.site
  ? new URL(`${base}/images/hitaveitan_bg.png`, Astro.site).toString()
  : `${base}/images/hitaveitan_bg.png`;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;
const faviconUrl = `${base}/favicon.svg`;
---
<!DOCTYPE html>
<html lang="is">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0a0e15" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href={faviconUrl} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Hitaveitan T5 Raid Guide" />
  <meta property="og:locale" content="is_IS" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1920" />
  <meta property="og:image:height" content="1080" />
  <meta property="og:image:alt" content="Hitaveitan T5 Raid Guide" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global define:vars={{ bgImageUrl: `url('${bgImageUrl}')` }}>
    body {
      background-color: var(--bg);
      background-image: var(--bgImageUrl);
      background-position: center top;
      background-size: cover;
      background-attachment: fixed;
      background-repeat: no-repeat;
    }
    /* Darkening overlay so content stays readable on top of the artwork */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: linear-gradient(180deg,
        rgba(10, 14, 21, 0.30) 0%,
        rgba(10, 14, 21, 0.55) 35%,
        rgba(10, 14, 21, 0.85) 70%,
        rgba(10, 14, 21, 0.95) 100%);
      z-index: -1;
      pointer-events: none;
    }
    /* iOS / mobile fallback — fixed bg attachments cause jitter on touch scroll */
    @media (max-width: 768px) {
      body { background-attachment: scroll; }
    }
  </style>
  <ClientRouter />
</head>
<body>
  <div class="progress" id="progress"></div>
  <slot />

  <script>
    // Reading progress bar
    const init = () => {
      const progress = document.getElementById('progress');
      if (!progress) return;
      const update = () => {
        const scrolled = window.scrollY;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        const pct = total > 0 ? (scrolled / total) * 100 : 0;
        progress.style.width = pct + '%';
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    };

    // IntersectionObserver fallback for browsers without animation-timeline: view()
    const setupReveals = () => {
      const supportsScrollTimeline = CSS.supports('animation-timeline: view()');
      if (supportsScrollTimeline) return;
      const targets = document.querySelectorAll('.boss, .raid-intro, .tips-card, .trash-group, .boss-figure');
      targets.forEach(el => el.classList.add('reveal'));
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      targets.forEach(el => io.observe(el));
    };

    // Boss difficulty-skull ignition: ignite left-to-right when each card enters view.
    // Runs in all browsers (independent of the reveals fallback), fires once per .boss.
    const setupSkullIgnition = () => {
      const targets = document.querySelectorAll<HTMLElement>('.boss');
      if (!targets.length) return;
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('ignited');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });
      targets.forEach(el => io.observe(el));
    };

    // Topnav scrollspy: highlight the current section + bubble up to mega-menu trigger
    const setupScrollspy = () => {
      const links = document.querySelectorAll<HTMLAnchorElement>('.topnav-links a, .megamenu a');
      if (!links.length) return;
      const linkByHash = new Map<string, HTMLAnchorElement>();
      links.forEach(a => {
        const hash = a.getAttribute('href');
        if (hash?.startsWith('#')) linkByHash.set(hash.slice(1), a);
      });
      const megamenus = document.querySelectorAll<HTMLElement>('.megamenu');
      const targets = Array.from(document.querySelectorAll<HTMLElement>('section[id], article[id]'));
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            links.forEach(a => a.classList.remove('active'));
            megamenus.forEach(d => d.setAttribute('data-active', 'false'));
            const link = linkByHash.get(id);
            if (link) {
              link.classList.add('active');
              const parent = link.closest<HTMLElement>('.megamenu');
              if (parent) parent.setAttribute('data-active', 'true');
            }
          }
        });
      }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
      targets.forEach(t => io.observe(t));
    };

    // Mega-menu tap-toggle (mobile/touch); desktop uses CSS :hover/:focus-within
    const setupDropdowns = () => {
      const dropdowns = Array.from(document.querySelectorAll<HTMLElement>('.megamenu'));
      if (!dropdowns.length) return;

      const closeAll = () => dropdowns.forEach(d => {
        d.setAttribute('data-open', 'false');
        d.querySelector('.megamenu-trigger')?.setAttribute('aria-expanded', 'false');
      });

      dropdowns.forEach(dd => {
        const trigger = dd.querySelector<HTMLButtonElement>('.megamenu-trigger');
        if (!trigger) return;
        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = dd.getAttribute('data-open') === 'true';
          closeAll();
          if (!open) {
            dd.setAttribute('data-open', 'true');
            trigger.setAttribute('aria-expanded', 'true');
          }
        });
        dd.querySelectorAll<HTMLAnchorElement>('a').forEach(a => {
          a.addEventListener('click', () => {
            dd.setAttribute('data-open', 'false');
            trigger.setAttribute('aria-expanded', 'false');
            // Blur so :focus-within releases on touch devices
            (document.activeElement as HTMLElement | null)?.blur?.();
          });
        });
      });

      document.addEventListener('click', (e) => {
        if (!(e.target as Element).closest('.megamenu')) closeAll();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAll();
      });
    };

    const boot = () => { init(); setupReveals(); setupSkullIgnition(); setupScrollspy(); setupDropdowns(); };
    document.addEventListener('astro:page-load', boot);
    if (document.readyState !== 'loading') boot();
    else document.addEventListener('DOMContentLoaded', boot);
  </script>
</body>
</html>
